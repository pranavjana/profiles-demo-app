# --- OpenRouter (LLM provider) ---------------------------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: any OpenRouter model slug. Must support tool calling.
# Examples: openai/gpt-5.4-mini, anthropic/claude-3.5-sonnet, google/gemini-2.5-pro
# Defaults to openai/gpt-5.4-mini if unset.
OPENROUTER_MODEL=openai/gpt-5.4-mini

# --- TinyFish (web agent + browser profiles) -------------------------------
# Get a key at https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=
